<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TIMECRAFT // v1.0</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
<div id="app">

  <div class="tc-header">
    <div class="tc-title">TIMECRAFT<span> // v1.0</span></div>
    <div class="tc-level-badge" id="level-badge">LVL 1 // RECRUIT</div>
  </div>

  <div class="tc-timer-panel">
    <div class="tc-timer-label" id="timer-status-label">STANDBY</div>
    <div class="tc-timer-display stopped" id="timer-display">00:00:00</div>
    <div class="tc-task-display" id="task-display"></div>
  </div>

  <div class="tc-task-row">
    <input class="tc-input" id="task-input" placeholder="> enter mission name..." maxlength="50" />
  </div>

  <div class="tc-btn-row">
    <button class="tc-btn primary" id="btn-start">[ START ]</button>
    <button class="tc-btn" id="btn-pause" disabled>[ PAUSE ]</button>
    <button class="tc-btn danger" id="btn-commit" disabled>[ COMMIT ]</button>
  </div>

  <div class="tc-stats">
    <div class="tc-stat">
      <div class="tc-stat-label">TODAY</div>
      <div class="tc-stat-value" id="stat-today">0m 0s</div>
    </div>
    <div class="tc-stat">
      <div class="tc-stat-label">SESSIONS</div>
      <div class="tc-stat-value" id="stat-sessions">0</div>
    </div>
    <div class="tc-stat">
      <div class="tc-stat-label">TOTAL XP</div>
      <div class="tc-stat-value" id="stat-xp">0 XP</div>
    </div>
    <div class="tc-stat">
      <div class="tc-stat-label">ALL TIME</div>
      <div class="tc-stat-value" id="stat-total">0m</div>
    </div>
  </div>

  <div class="tc-xp-bar-wrap">
    <div class="tc-xp-row">
      <span id="xp-label">XP PROGRESS</span>
      <span id="xp-pct">0 / 60 XP</span>
    </div>
    <div class="tc-xp-track">
      <div class="tc-xp-fill" id="xp-fill" style="width: 0%"></div>
    </div>
  </div>

  <div class="tc-log-header">
    <span>◈ MISSION LOG</span>
    <button class="tc-log-clear" id="clear-log">[ CLEAR ALL ]</button>
  </div>
  <div class="tc-log" id="log-list">
    <div class="tc-empty">NO MISSIONS LOGGED YET</div>
  </div>

</div>

<script src="app.js"></script>
</body>
</html>
